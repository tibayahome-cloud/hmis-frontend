## Server-side backend URL (never sent to the browser)
##
## Local dev (both services running natively):
##   API_BASE=http://localhost:8000
##
## Docker standalone frontend (backend running natively or via its own compose):
##   API_BASE=http://host.docker.internal:8000
##
## Docker full-stack compose (both services in the same docker-compose network):
##   API_BASE=http://backend:8000
##
API_BASE=http://localhost:8000/api/v1
